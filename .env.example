# Template of every env var. Never commit real secrets.
# Vars are validated by env.ts — uncomment them there as each integration is wired.
#
# Environments (Next.js loads these automatically by NODE_ENV):
#   .env.development  -> `next dev`            -> LOCAL Supabase stack (npm run db:start)
#   .env.production   -> `next build`/`start`  -> REAL cloud Supabase project
#   .env.local        -> overrides BOTH; keep empty unless you need a personal override
# All .env* files except this one are gitignored.

# --- Supabase --- new-format API keys (sb_publishable_... / sb_secret_...)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Resend (F1.5 booking confirmation emails) ---
# Leave blank in dev/CI: the email layer logs payloads instead of sending.
# Set both to send for real (RESEND_API_KEY=re_..., EMAIL_FROM must be a verified domain).
RESEND_API_KEY=
EMAIL_FROM=

# --- Admin alerts ---
# Where operator-change notifications go (e.g. a GCash change). Comma-separated for multiple.
# If blank, alerts fall back to operators with is_admin=true.
ADMIN_ALERT_EMAIL=

# --- Cron secret (Phase A — subscription billing cron) ---
# Shared secret the scheduler sends as `Authorization: Bearer <CRON_SECRET>` to
# /api/cron/subscription-billing (flips past-due plans + emails renewal reminders).
# Blank = the cron route refuses all calls (dormant).
CRON_SECRET=

# --- Subscription enforcement switch (OFF during the pilot) ---
# "true" = the billing cron downgrades operators past-due beyond the grace window to free.
# Unset/anything else = nag-only (the pilot default). Flip after the pilot.
SUBSCRIPTION_ENFORCEMENT=

# --- PayMongo (Phase 2a spike) --- operator-as-merchant gateway.
# Leave blank unless testing the gateway: a SINGLE sandbox account's keys (sk_test_... + the
# webhook's whsk_...). Phase 2b moves operator keys to a per-tenant encrypted store, not env.
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=

# --- PayMongo PLATFORM account (operator subscription billing) ---
# Tuloy's OWN PayMongo account (operators pay US for the software — a separate rail from the gateway
# above). Secret key signs the subscription checkout; whsk_ verifies its webhook
# (https://SITE_URL/api/webhooks/paymongo/subscription). Blank = subscription checkout dormant.
PAYMONGO_PLATFORM_SECRET_KEY=
PAYMONGO_PLATFORM_WEBHOOK_SECRET=

# --- Upgrade contact (Phase 3) ---
# Messenger link the operator-facing "Upgrade" CTA opens (billing is manual-first, B4).
# Blank = the CTA shows plain "message us" copy with no link. e.g. https://m.me/yourpage
NEXT_PUBLIC_UPGRADE_MESSENGER_URL=https://www.facebook.com/racyn.mundina.ibaya.ii
